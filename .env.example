# PrivacyShield Environment Configuration
# Copy this file to .env and fill in your values

# ============ Algorand TestNet ============
ALGORAND_ALGOD_URL=https://testnet-api.algonode.cloud
ALGORAND_ALGOD_TOKEN=
ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud

# Account mnemonic for signing transactions (TestNet only!)
# Generate at: https://app.daffi.me/ or via `algokit account create`
ALGORAND_MNEMONIC=

# Deployed contract App IDs (filled after deployment)
VERIFIER_APP_ID=
CONSENT_MANAGER_APP_ID=

# ============ Backend ============
PORT=8080

# ============ Frontend ============
VITE_API_URL=http://localhost:8080
